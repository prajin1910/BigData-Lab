# mapper.py
import sys

for line in sys.stdin:
    words = line.strip().split()

    for word in words:
        if word.lower().startswith('r'):
            print("R\t1")

# reducer.py
import sys

count = 0

for line in sys.stdin:
    key, value = line.strip().split('\t')
    count += int(value)

print("Words starting with R :", count)
