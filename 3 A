# mapper.py
import sys

for line in sys.stdin:
    words = line.strip().split()

    for word in words:
        print(word.lower() + "\t1")



# reducer.py
import sys

dict1 = {}

for line in sys.stdin:
    word, count = line.strip().split('\t')

    dict1[word] = dict1.get(word,0) + int(count)

for k,v in dict1.items():
    if v > 10:
        print(k,v)
