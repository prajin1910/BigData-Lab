import pandas as pd
from sklearn.linear_model import LogisticRegression

data = {
    'Hours':[2,4,6,8,10],
    'Percentage':[40,50,60,80,90],
    'Interest':[1,1,0,1,1],
    'Result':[0,0,1,1,1]
}

df = pd.DataFrame(data)

x = df[['Hours','Percentage','Interest']]
y = df['Result']

model = LogisticRegression()
model.fit(x,y)

test = [[5,70,1]]

result = model.predict(test)

if result[0] == 1:
    print("Pass")
else:
    print("Fail")
