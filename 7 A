import pandas as pd
import matplotlib.pyplot as plt

data = {
    'Age':[20,25,30,35,40],
    'Income':[20000,30000,40000,50000,60000]
}

df = pd.DataFrame(data)

plt.plot(df['Age'],df['Income'])
plt.show()

plt.bar(df['Age'],df['Income'])
plt.show()

plt.scatter(df['Age'],df['Income'])
plt.show()

plt.hist(df['Income'])
plt.show()

plt.pie(df['Income'], labels=df['Age'], autopct='%1.1f%%')
plt.show()
